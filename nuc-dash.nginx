server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name nuc.jackrose.website;

    root /var/www/nuc-dash;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
}
